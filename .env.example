# =====================================================
# LEVISTRO — Configuración del proyecto
# Copiá este archivo como .env y completá tus valores
# =====================================================

# --- LANGSMITH (monitoreo — opcional) ---
# Obtené tu clave en https://smith.langchain.com → Settings → API Keys
LANGCHAIN_API_KEY=tu_clave_aqui
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=nombre-de-tu-proyecto

# --- QDRANT ---
QDRANT_URL=http://localhost:6333
# Nombre de tu colección — usá el nombre de tu proyecto
QDRANT_COLLECTION=mi-biblioteca

# --- TESSERACT (para PDFs escaneados) ---
# Windows: descargar de https://github.com/UB-Mannheim/tesseract/wiki
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# --- POPPLER (para convertir PDFs a imágenes) ---
# Windows: descargar de https://github.com/oschwartz10612/poppler-windows/releases
# Extraer en la carpeta del proyecto y apuntar a la carpeta bin/
POPPLER_PATH=ruta\a\poppler\bin

# --- OLLAMA (modelos locales) ---
OLLAMA_BASE_URL=http://localhost:11434
